[core]
	repositoryFormatVersion = 1
	filemode = true
[filter "lfs"]
	smudge = git-lfs smudge --skip -- %f
	process = git-lfs filter-process --skip
[remote "origin"]
	url = https://github.com/seL4/camkes-manifest.git
	fetch = +refs/heads/*:refs/remotes/origin/*
[manifest]
	platform = auto
[extensions]
	preciousObjects = true
[branch "default"]
	remote = origin
	merge = refs/heads/master
[user]
	name = ьmak
[repo]
	existingprojectcount = 0
	newprojectcount = 18
[repo "syncstate.main"]
	synctime = 2026-03-14T12:00:00.802536+00:00
	version = 1
[repo "syncstate.sys"]
	argv = ['/root/hk_project/.repo/repo/main.py', '--repo-dir=/root/hk_project/.repo', '--wrapper-version=2.54', '--wrapper-path=/root/bin/repo', '--', 'sync']
[repo "syncstate.options"]
	jobs = 8
	outermanifest = true
	jobsnetwork = 1
	jobscheckout = 8
	mpupdate = true
	interleaved = true
	clonebundle = true
	retryfetches = 0
	prune = true
	repoverify = true
	quiet = false
	verbose = false
[repo "syncstate.remote.origin"]
	url = https://github.com/seL4/camkes-manifest.git
	fetch = +refs/heads/*:refs/remotes/origin/*
[repo "syncstate.branch.default"]
	remote = origin
	merge = refs/heads/master
[repo "syncstate.repo"]
	existingprojectcount = 0
	newprojectcount = 18
